# =============================================================================
# Restaurante — variables de entorno (backend Laravel)
# =============================================================================
# Copia este archivo y genera la clave de aplicación:
#   cp .env.example .env          (Linux/macOS)
#   copy .env.example .env        (Windows)
#   php artisan key:generate
#
# Guía completa: docs/INSTALACION.md
# Multi-tenant:  docs/TENANCY.md
# OAuth Google:  docs/GOOGLE_OAUTH.md
# =============================================================================

# --- Aplicación ---
APP_NAME="Restaurante"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
APP_LOCALE=es
APP_FALLBACK_LOCALE=en

# URL del frontend (enlaces de correo, reset de contraseña, OAuth)
FRONTEND_URL=http://127.0.0.1:5173

# --- Base de datos (modo single: un solo restaurante) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=restaurante
DB_USERNAME=root
DB_PASSWORD=

# --- Multi-tenant (opcional; por defecto single) ---
# Ver docs/TENANCY.md para desplegar varios restaurantes.
TENANCY_MODE=single

# Descomenta y configura si TENANCY_MODE=multi:
# DB_MASTER_DATABASE=restaurante_master
# TENANT_BASE_DOMAIN=localhost
# TENANT_MASTER_SUBDOMAIN=master
# TENANT_TEMPLATE_DATABASE=restaurante
# TENANT_DATABASE_PREFIX=rest_
# TENANT_RESERVED_SUBDOMAINS=www,api,onboarding,mail
# TENANT_ONBOARDING_TTL_HOURS=72
# TENANT_DEFAULT_LICENSE_MONTHS=1
# TENANT_LICENSE_WARNING_DAYS=7
# TENANT_FRONTEND_SCHEME=http
# TENANT_FRONTEND_HOST=127.0.0.1
# TENANT_FRONTEND_PORT=5173
# TENANT_DEFAULT_SLUG=

# Usuario Master (solo al ejecutar: php artisan master:migrate --seed)
# MASTER_ADMIN_EMAIL=master@local.test
# MASTER_ADMIN_NAME="Master Admin"
# MASTER_ADMIN_PASSWORD=
# MASTER_SECOND_EMAIL=
# MASTER_SECOND_NAME=
# MASTER_SECOND_PASSWORD=

# --- Sesión, caché y colas ---
SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=database

# --- Logs ---
LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Correo (desarrollo: log; producción: smtp) ---
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Producción (ejemplo Gmail con contraseña de aplicación):
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=tu-correo@gmail.com
# MAIL_PASSWORD=contraseña-de-aplicacion
# MAIL_ENCRYPTION=tls

# --- Autenticación API (Sanctum) ---
# Duración del token en minutos (720 = 12 horas)
SANCTUM_TOKEN_EXPIRATION=720

# Dominios del SPA que pueden usar cookies stateful (producción: tu dominio real)
# SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:5173

# --- Rate limiting (intentos por minuto) ---
AUTH_RATE_LIMIT=6
ONBOARDING_RATE_LIMIT=30
ONBOARDING_COMPLETE_RATE_LIMIT=5

# --- Google OAuth (clientes) — ver docs/GOOGLE_OAUTH.md ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/cliente/callback"

# --- Almacenamiento de archivos (imágenes de productos) ---
FILESYSTEM_DISK=local

# --- SSL en Windows (opcional; el proyecto incluye backend/certs/cacert.pem) ---
# SSL_CA_BUNDLE=

# =============================================================================
# PRODUCCIÓN — revisar antes de desplegar
# =============================================================================
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://api.tudominio.com
# FRONTEND_URL=https://tudominio.com
# MAIL_MAILER=smtp
# SANCTUM_STATEFUL_DOMAINS=tudominio.com,www.tudominio.com
# TENANCY_MODE=multi   (si aplica)
